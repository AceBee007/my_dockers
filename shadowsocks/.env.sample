# Shadowsocks server password (required)
PASSWORD=change_me_to_a_strong_password

# Host port to expose (default: 8388)
PORT=8388

# Encryption method (default: chacha20-ietf-poly1305)
METHOD=chacha20-ietf-poly1305

# Connection timeout in seconds (default: 300)
TIMEOUT=180

# DNS servers (default: 8.8.8.8,8.8.4.4)
DNS_ADDRS=1.1.1.1,8.8.8.8,1.0.0.1,8.8.4.4

# simple-obfs plugin (obfs=http or obfs=tls)
ARGS=--plugin obfs-server --plugin-opts obfs=http;fast-open
